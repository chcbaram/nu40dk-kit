  "version": "0.2.0",
  "configurations": [
    {
      "cwd": "${workspaceFolder}",
      "executable": "build/nu40dk-kit-led/zephyr/zephyr.elf",
      "name": "Debug with PyOCD",
      "request": "launch",
      "type": "cortex-debug",
      "serverArgs": [
        "--target", "nrf52",     
      ],
      "runToEntryPoint": "main",
      "showDevDebugOutput": "none",
      "servertype": "pyocd"
    },
  ]
}